#!/bin/bash
#SBATCH --job-name=RG
#SBATCH --mem=50G

# Load Java and Picard modules
module load Java/17.0.6 
module load picard/3.0.0-Java-17

INPUT_DIR="/.../Catinca/NRH-OS1/WGS/Output/Remove_dups/NRHOS1_remove_dups.bam"
OUTPUT_DIR="/.../Catinca/NRH-OS1/WGS/Output/ReadGroups/Duplicates_removed"
LOG_DIR="/.../Catinca/NRH-OS1/WGS/Output/ReadGroups/Duplicates_removed/picard/FASTP"
SAMPLE="NRHOS1"

# Create directory if it doesn't exist
mkdir -p "${OUTPUT_DIR}"
mkdir -p "${LOG_DIR}"

# Run Picard command
java -jar $EBROOTPICARD/picard.jar AddOrReplaceReadGroups \
    I="${INPUT_DIR}" \
    O="${OUTPUT_DIR}/NRHOS1_FASTP_Duplicates_removed.bam" \
    RGID="${SAMPLE}" \
    RGLB="lib1" \
    RGPL="illumina" \
    RGPU="${SAMPLE}" \
    RGSM="${SAMPLE}" \
    &> "${LOG_DIR}/${SAMPLE}_addreplace_rg.log"
