#!/bin/bash
#SBATCH --job-name=star_fusion
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH -p long

module load STAR
module load SAMtools/1.18-GCC-12.3.0
mkdir -p /.../NRH-OS1/RNA_seq/Output/STAR-fusion-Trinity/3

ctat_lib_dir="/.../Bioinformatics_resources/Resources/GRCh38_gencode_v37_CTAT_lib_Mar012021.plug-n-play/ctat_genome_lib_build_dir"
fusion_output_dir="/.../NRH-OS1/RNA_seq/Output/STAR-fusion-Trinity/3"

# Define paths to the paired-end FASTQ files
fastq_r1="/.../NRH-OS1/RNA_seq/FASTQ_raw_files/RNASeq_Azenta_OS1/Raw_Files/NRH-OS1-3_R1_001.fastq.gz"
fastq_r2="/.../NRH-OS1/RNA_seq/FASTQ_raw_files/RNASeq_Azenta_OS1/Raw_Files/NRH-OS1-3_R2_001.fastq.gz"
#path to STAR-Fusion
export STARFUSION_HOME=/.../NRH-OS1/RNA_seq/STAR_env/STAR-Fusion-v1.15.1
export TRINITY_HOME=$STARFUSION_HOME/trinityrnaseq-v2.15.2

export PATH="$STARFUSION_HOME/FusionInspector/util:$STARFUSION_HOME:$STARFUSION_HOME/FusionInspector:$TRINITY_HOME:/users/hassan/xcc033/software/minimap2-2.30_x64-linux:$PATH"
export PATH="$HOME/software/minimap2-2.30_x64-linux:$PATH"
export PATH=/.../NRH-OS1/RNA_seq/STAR_env/STAR-Fusion-v1.15.1:$PATH
export PATH=/apps/eb/el8/2023a/skylake/software/SAMtools/1.18-GCC-12.3.0/bin:$PATH
export PATH="$STARFUSION_HOME:$STARFUSION_HOME/FusionInspector:$TRINITY_HOME:$PATH"
export PERL5LIB="$STARFUSION_HOME/FusionInspector/PerlLib:$STARFUSION_HOME/FusionInspector/PyLib:$TRINITY_HOME/PerlLib:${PERL5LIB:-}"
export PATH="$HOME/.local/bin:$PATH"
which samtools 
STAR-Fusion \
    --genome_lib_dir "$ctat_lib_dir" \
    --left_fq "$fastq_r1" \
    --right_fq "$fastq_r2" \
    --output_dir "$fusion_output_dir" \
    --FusionInspector validate \
    --examine_coding_effect \
    --denovo_reconstruct \
    --CPU 8

fastqc -dir /.../HOS/RNA_seq/Output/Analysis/Code/TMPDIR -o /.../HOS/RNA_seq/Output/FASTQC_after_cut  /.../HOS/RNA_seq/Output/Cutadapt/cutadapt_HOS1_R1_001.fastq /.../HOS/RNA_seq/Output/Cutadapt/cutadapt_HOS1_R2_001.fastq /.../HOS/RNA_seq/Output/Cutadapt/cutadapt_HOS2_R1_001.fastq /.../HOS/RNA_seq/Output/Cutadapt/cutadapt_HOS2_R2_001.fastq /.../HOS/RNA_seq/Output/Cutadapt/cutadapt_HOS3_R1_001.fastq /.../HOS/RNA_seq/Output/Cutadapt/cutadapt_HOS3_R2_001.fastq
